{
  "name": "tokeianarogu",
  "version": "1.0.0",
  "description": "Multi-platform analog clock app - Web, Desktop, Android, iOS",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=packages/web",
    "desktop": "npm run dev --workspace=packages/desktop",
    "mobile": "npm run start --workspace=packages/mobile",
    "build:web": "npm run build --workspace=packages/web",
    "build:desktop": "npm run build --workspace=packages/desktop",
    "build:android": "npm run build:android --workspace=packages/mobile",
    "build:ios": "npm run build:ios --workspace=packages/mobile"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
