{
  "name": "@tokeianarogu/desktop",
  "version": "1.0.0",
  "description": "Analog clock desktop app - Electron",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run web:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "web:dev": "npm run dev --workspace=../web",
    "build": "tsc -p tsconfig.json && electron-builder",
    "build:win": "tsc -p tsconfig.json && electron-builder --win",
    "build:mac": "tsc -p tsconfig.json && electron-builder --mac",
    "build:linux": "tsc -p tsconfig.json && electron-builder --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tokeianarogu.app",
    "productName": "時計アナログ",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../web/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage", "deb"]
    }
  }
}
